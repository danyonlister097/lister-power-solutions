# App
PORT=3000
SESSION_SECRET=change_me_to_a_random_string

# Database (Neon Postgres - use the POOLED connection string, hostname
# contains "-pooler", so serverless invocations share connections via
# PgBouncer instead of exhausting Neon's direct connection limit)
DATABASE_URL=postgresql://user:password@ep-example-123456-pooler.region.aws.neon.tech/neondb?sslmode=require

# File storage (Vercel Blob - create a store under the Vercel project's
# Storage tab, then copy its read/write token)
BLOB_READ_WRITE_TOKEN=

# First admin account (created by `npm run seed:admin`)
ADMIN_NAME=Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# MYOB (kept dormant for now - future invoice push, not used by the app yet)
MYOB_ENABLED=false
MYOB_CLIENT_ID=
MYOB_CLIENT_SECRET=
MYOB_REDIRECT_URI=http://localhost:3000/oauth/callback
MYOB_REFRESH_TOKEN=
MYOB_COMPANY_FILE_ID=
MYOB_COMPANY_FILE_USERNAME=
MYOB_COMPANY_FILE_PASSWORD=
MYOB_DEFAULT_INCOME_ACCOUNT_UID=
MYOB_DEFAULT_TAX_CODE_UID=

# Email (Microsoft 365 / Outlook SMTP)
# SMTP_USER = your full email address, e.g. admin@listerpowersolutions.com.au
# SMTP_PASS = your email password (or an app password if MFA is enabled)
# Until these are set, emails are logged to console instead of sent.
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Lister Power Solutions <admin@listerpowersolutions.com.au>
# Real deployed URL, used to build links inside emails (password reset, etc.)
APP_URL=http://localhost:3000

# Microsoft Graph API (for automated CNW invoice email processing)
# Register an app in Azure portal → Microsoft Entra ID → App registrations
# Grant it: Microsoft Graph → Application permissions → Mail.Read
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# The mailbox to monitor for supplier invoices (your admin email)
GRAPH_MAILBOX=admin@listerpowersolutions.com.au

LOG_LEVEL=info
