<%- include('../partials/header', { title: folder.name }) %>
<div class="page-header">
  <h1><%= folder.name %><% if (folder.customer_name) { %> <span class="folder-header-customer">&middot; <%= folder.customer_name %></span><% } %></h1>
  <div class="actions">
    <a class="btn btn-secondary btn-sm" href="/chat/folders">All folders</a>
    <% if (currentUser.role === 'admin') { %>
      <form method="post" action="/chat/folders/<%= folder.id %>/delete" data-confirm="Delete this folder and all its photos? This cannot be undone.">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-danger btn-sm">Delete folder</button>
      </form>
    <% } %>
  </div>
</div>

<% if (images.length === 0) { %>
  <p class="text-muted">No photos in this folder yet.</p>
<% } else { %>
  <div class="attachment-grid">
    <% images.forEach(img => { %>
      <div class="attachment-item">
        <a href="/chat/folders/<%= folder.id %>/images/<%= img.id %>" target="_blank" rel="noopener">
          <img src="/chat/folders/<%= folder.id %>/images/<%= img.id %>" alt="<%= img.original_name %>">
        </a>
        <% if (img.uploaded_by === currentUser.id || currentUser.role === 'admin') { %>
          <form method="post" action="/chat/folders/<%= folder.id %>/images/<%= img.id %>/delete"
                data-confirm="Remove this photo?">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="attachment-delete" aria-label="Remove photo">&times;</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </div>
<% } %>

<form method="post" action="/chat/folders/<%= folder.id %>/images" enctype="multipart/form-data" class="attachment-upload-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>
    Add photos
    <input type="file" name="photos" accept="image/*" multiple>
  </label>
  <button type="submit" class="btn btn-primary">Upload</button>
</form>
<%- include('../partials/footer') %>
