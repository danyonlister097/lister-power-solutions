<div id="confirm-modal" class="modal-backdrop" hidden>
  <div class="modal modal-confirm" role="alertdialog" aria-modal="true" aria-labelledby="confirm-modal-title">
    <h2 id="confirm-modal-title">Are you sure?</h2>
    <p id="confirm-modal-message"></p>
    <div class="actions">
      <button type="button" class="btn btn-secondary" id="confirm-modal-cancel">Cancel</button>
      <button type="button" class="btn btn-danger" id="confirm-modal-ok">Delete</button>
    </div>
  </div>
</div>
