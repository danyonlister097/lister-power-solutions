<%- include('../partials/header', { title: 'Quotes', wide: true }) %>
<div class="page-header">
  <h1>Quotes</h1>
  <button type="button" class="btn btn-primary" id="new-quote-open">+ New Quote</button>
</div>

<div class="filters">
  <a class="<%= status === '' ? 'active' : '' %>" href="/quotes">All</a>
  <a class="<%= status === 'draft' ? 'active' : '' %>" href="/quotes?status=draft">Draft</a>
  <a class="<%= status === 'sent' ? 'active' : '' %>" href="/quotes?status=sent">Sent</a>
  <a class="<%= status === 'accepted' ? 'active' : '' %>" href="/quotes?status=accepted">Accepted</a>
  <a class="<%= status === 'declined' ? 'active' : '' %>" href="/quotes?status=declined">Declined</a>
</div>

<div class="section-heading">Quotes (<%= quotes.length %>)</div>
<% if (!quotes.length) { %>
  <p class="text-muted">No quotes yet.</p>
<% } else { %>
  <div class="timesheet-scroll">
    <table class="timesheet-table">
      <thead>
        <tr>
          <th>Quote #</th>
          <th>Title</th>
          <th>Customer</th>
          <th>Status</th>
          <th>Total</th>
          <th>Created</th>
        </tr>
      </thead>
      <tbody>
        <% quotes.forEach(q => { %>
          <tr>
            <td><a href="/quotes/<%= q.id %>"><%= q.quote_number %></a></td>
            <td><%= q.title %></td>
            <td><%= q.customer_name %></td>
            <td><span class="badge badge-<%= q.status %>"><%= q.status %></span></td>
            <td><%= formatMoney(q.total) %></td>
            <td><%= formatAuDate(q.created_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<div id="new-quote-modal" class="modal-backdrop" hidden>
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="new-quote-modal-title">
    <button type="button" class="modal-close" id="new-quote-close" aria-label="Close">&times;</button>
    <h2 id="new-quote-modal-title">New quote</h2>
    <form method="post" action="/quotes">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>
        Customer
        <select name="customer_id" required>
          <option value="">Select a customer&hellip;</option>
          <% customers.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </label>
      <label>
        Title
        <input type="text" name="title" required maxlength="120" placeholder="e.g. Switchboard upgrade">
      </label>
      <label>
        Notes (optional)
        <textarea name="notes" rows="3"></textarea>
      </label>
      <div class="actions">
        <button type="submit" class="btn btn-primary">Create quote</button>
      </div>
    </form>
  </div>
</div>
<script>
  (function () {
    var modal = document.getElementById('new-quote-modal');
    var openBtn = document.getElementById('new-quote-open');
    var closeBtn = document.getElementById('new-quote-close');

    openBtn.addEventListener('click', function () { modal.hidden = false; });
    closeBtn.addEventListener('click', function () { modal.hidden = true; });
    modal.addEventListener('click', function (e) {
      if (e.target === modal) modal.hidden = true;
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.hidden) modal.hidden = true;
    });
  })();
</script>
<%- include('../partials/footer') %>
