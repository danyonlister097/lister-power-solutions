<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Quote - <%= quote.title %></title>
  <style>
    * { box-sizing: border-box; }
    body { font-family: Arial, Helvetica, sans-serif; color: #1a1a1a; margin: 2.5rem; }
    .print-header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 3px solid #1a1a1a; padding-bottom: 1rem; margin-bottom: 1.5rem; }
    .print-header img { height: 48px; }
    .print-header h1 { font-size: 1.1rem; margin: 0.5rem 0 0; }
    .quote-meta { text-align: right; font-size: 0.9rem; }
    .quote-meta .status { display: inline-block; margin-top: 0.35rem; padding: 0.2rem 0.6rem; border-radius: 999px; background: #e6e9ee; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; }
    .bill-to { margin-bottom: 1.5rem; }
    .bill-to h2 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: #666; margin-bottom: 0.25rem; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
    th, td { text-align: left; padding: 0.5rem 0.6rem; border-bottom: 1px solid #ddd; font-size: 0.9rem; }
    th { background: #f4f5f7; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.03em; color: #555; }
    td.num, th.num { text-align: right; }
    .totals { display: flex; justify-content: flex-end; }
    .totals table { width: 260px; margin-bottom: 0; }
    .totals td { border-bottom: none; padding: 0.35rem 0.6rem; }
    .totals tr.grand td { font-weight: 700; font-size: 1.05rem; border-top: 2px solid #1a1a1a; }
    .notes { margin-top: 1.5rem; font-size: 0.9rem; }
    .print-actions { margin-bottom: 1.5rem; }
    @media print { .print-actions { display: none; } body { margin: 1rem; } }
  </style>
</head>
<body>
  <div class="print-actions">
    <button onclick="window.print()">Print / Save as PDF</button>
  </div>

  <div class="print-header">
    <div>
      <img src="/img/logo-icon.png" alt="">
      <h1>Lister Power Solutions</h1>
    </div>
    <div class="quote-meta">
      <div><strong>Quote</strong></div>
      <div>Quote #: <%= quote.quote_number %></div>
      <div>Issue date: <%= formatAuDate(quote.created_at) %></div>
      <div class="status"><%= quote.status %></div>
    </div>
  </div>

  <div class="bill-to">
    <h2>Bill to</h2>
    <div><strong><%= quote.customer_name %></strong></div>
    <% if (quote.customer_email) { %><div><%= quote.customer_email %></div><% } %>
    <% if (quote.customer_phone) { %><div><%= quote.customer_phone %></div><% } %>
    <% if (quote.address_street) { %><div><%= quote.address_street %>, <%= [quote.address_city, quote.address_state, quote.address_postcode].filter(Boolean).join(' ') %></div><% } %>
  </div>

  <h2 style="font-size: 1rem;"><%= quote.title %></h2>

  <table>
    <thead>
      <tr>
        <th>Description</th>
        <th>Category</th>
        <th class="num">Qty</th>
        <th class="num">Unit price</th>
        <th class="num">Amount</th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach(i => { %>
        <tr>
          <td><%= i.description %></td>
          <td><%= i.category %></td>
          <td class="num"><%= i.quantity %></td>
          <td class="num"><%= formatMoney(i.unit_price) %></td>
          <td class="num"><%= formatMoney(i.quantity * i.unit_price) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="totals">
    <table>
      <tr><td>Subtotal (ex. GST)</td><td class="num"><%= formatMoney(subtotal) %></td></tr>
      <tr><td>GST (10%)</td><td class="num"><%= formatMoney(gst) %></td></tr>
      <tr class="grand"><td>Total (inc. GST)</td><td class="num"><%= formatMoney(total) %></td></tr>
    </table>
  </div>

  <% if (quote.notes) { %>
    <div class="notes">
      <h2 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: #666;">Notes</h2>
      <p><%= quote.notes %></p>
    </div>
  <% } %>
</body>
</html>
