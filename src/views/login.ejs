<%- include('partials/header', { title: 'Log in' }) %>
<div class="login-page">
  <div class="card card-narrow login-card">
    <img src="/img/logo-full.png" alt="Lister Power Solutions" class="login-logo">
    <h1>Welcome back</h1>
    <p class="login-subtitle">Log in to Lister Power Solutions</p>
    <% if (error) { %>
      <div class="flash flash-error"><%= error %></div>
    <% } %>
    <form method="post" action="/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>
        Email
        <input type="email" name="email" required autofocus>
      </label>
      <label>
        Password
        <input type="password" name="password" required>
      </label>
      <button type="submit" class="btn btn-primary login-submit">Log in</button>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
