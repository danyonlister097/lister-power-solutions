<%- include('../partials/header', { title: title }) %>
<h1><%= title %></h1>

<form method="post" action="<%= targetUser.id ? `/users/${targetUser.id}` : '/users' %>" class="card">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <% if (error) { %>
    <div class="flash flash-error">
      <%= error %>
      <% if (typeof existingUser !== 'undefined' && existingUser) { %>
        <a href="/users/<%= existingUser.id %>/edit">Edit <%= existingUser.name %> instead</a>
      <% } %>
    </div>
  <% } %>

  <label>
    Name *
    <input type="text" name="name" value="<%= targetUser.name || '' %>" required autofocus>
  </label>

  <label>
    Email *
    <input type="email" name="email" value="<%= targetUser.email || '' %>" required>
  </label>

  <div class="form-row form-row-2">
    <label>
      Role
      <select name="role">
        <option value="trade" <%= (targetUser.role || 'trade') === 'trade' ? 'selected' : '' %>>Trade</option>
        <option value="apprentice" <%= targetUser.role === 'apprentice' ? 'selected' : '' %>>Apprentice</option>
        <option value="admin" <%= targetUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
      </select>
    </label>
    <label>
      Rate <span style="font-weight:400;">(admin-only, used for labour cost totals)</span>
      <select name="hourly_rate">
        <option value="" <%= targetUser.hourly_rate == null ? 'selected' : '' %>>No rate set</option>
        <option value="110" <%= String(targetUser.hourly_rate) === '110' ? 'selected' : '' %>>Trade &mdash; $110/hr</option>
        <option value="80" <%= String(targetUser.hourly_rate) === '80' ? 'selected' : '' %>>4th year &mdash; $80/hr</option>
        <option value="70" <%= String(targetUser.hourly_rate) === '70' ? 'selected' : '' %>>3rd year &mdash; $70/hr</option>
        <option value="65" <%= String(targetUser.hourly_rate) === '65' ? 'selected' : '' %>>2nd year &mdash; $65/hr</option>
        <option value="60" <%= String(targetUser.hourly_rate) === '60' ? 'selected' : '' %>>1st year &mdash; $60/hr</option>
      </select>
    </label>
  </div>

  <% if (targetUser.id) { %>
    <label>
      <input type="checkbox" name="active" value="1" style="display:inline-block;width:auto;" <%= targetUser.active ? 'checked' : '' %>>
      Active
    </label>
    <label>
      New password <span style="font-weight:400;">(leave blank to keep current password)</span>
      <input type="password" name="password" id="user-password-field" minlength="8" autocomplete="new-password">
    </label>
  <% } else { %>
    <label>
      Password *
      <input type="password" name="password" required minlength="8" autocomplete="new-password">
    </label>
  <% } %>

  <div class="section-heading" style="margin-top:1.5rem;">Contact details</div>

  <div class="form-row form-row-2">
    <label>
      Personal phone
      <input type="tel" name="phone_personal" value="<%= targetUser.phone_personal || '' %>">
    </label>
    <label>
      Work phone
      <input type="tel" name="phone_work" value="<%= targetUser.phone_work || '' %>">
    </label>
  </div>

  <div class="form-row form-row-3">
    <label>
      Emergency contact name
      <input type="text" name="emergency_contact_name" value="<%= targetUser.emergency_contact_name || '' %>">
    </label>
    <label>
      Emergency contact phone
      <input type="tel" name="emergency_contact_phone" value="<%= targetUser.emergency_contact_phone || '' %>">
    </label>
    <label>
      Relationship
      <input type="text" name="emergency_contact_relation" value="<%= targetUser.emergency_contact_relation || '' %>" placeholder="e.g. Spouse, Parent">
    </label>
  </div>

  <div class="section-heading" style="margin-top:1.5rem;">Home address</div>

  <label>
    Street
    <input type="text" name="address_street" value="<%= targetUser.address_street || '' %>" placeholder="e.g. 12 Example St">
  </label>

  <div class="form-row form-row-3">
    <label>
      City / Suburb
      <input type="text" name="address_city" value="<%= targetUser.address_city || '' %>">
    </label>
    <label>
      State
      <input type="text" name="address_state" value="<%= targetUser.address_state || '' %>" placeholder="e.g. QLD">
    </label>
    <label>
      Postcode
      <input type="text" name="address_postcode" value="<%= targetUser.address_postcode || '' %>" inputmode="numeric" maxlength="4">
    </label>
  </div>

  <div class="permissions-field">
    <div class="permissions-label">
      Page &amp; tool access
      <span id="permissions-admin-note" style="font-weight:400;<%= (targetUser.role || 'trade') === 'admin' ? '' : 'display:none;' %>">
        Admins always have full access to everything, regardless of these boxes.
      </span>
    </div>
    <div class="permissions-grid" id="permissions-grid" data-defaults='<%- JSON.stringify(DEFAULT_KEYS_BY_ROLE) %>' data-is-new="<%= targetUser.id ? '0' : '1' %>">
      <% PERMISSIONS.forEach(p => { %>
        <label class="permissions-item">
          <input type="checkbox" name="permissions" value="<%= p.key %>" <%= selectedPermissions.includes(p.key) ? 'checked' : '' %>>
          <%= p.label %>
        </label>
      <% }) %>
    </div>
  </div>

  <div class="actions">
    <button type="submit" class="btn btn-primary">Save employee</button>
    <a class="btn btn-secondary" href="/users">Cancel</a>
  </div>
</form>

<script>
  (function () {
    var grid = document.getElementById('permissions-grid');
    var roleSelect = document.querySelector('select[name="role"]');
    var adminNote = document.getElementById('permissions-admin-note');
    if (!grid || !roleSelect) return;

    var defaults = JSON.parse(grid.getAttribute('data-defaults'));
    var isNew = grid.getAttribute('data-is-new') === '1';

    roleSelect.addEventListener('change', function () {
      adminNote.style.display = roleSelect.value === 'admin' ? '' : 'none';
      // Re-applying "smart" defaults only makes sense while there's nothing
      // to lose yet - on an edit, the admin may have deliberately customised
      // these away from the role's defaults, so switching role shouldn't
      // silently wipe that out.
      if (!isNew) return;
      var keys = defaults[roleSelect.value] || [];
      grid.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
        cb.checked = keys.indexOf(cb.value) !== -1;
      });
    });
  })();
</script>

<% if (targetUser.id) { %>
  <script>
    // Password managers/autofill can populate this field without the admin
    // meaning to change anything - a silent password change on save would
    // lock the account owner out with no obvious cause, so confirm first.
    (function () {
      var form = document.getElementById('user-password-field').closest('form');
      var confirmed = false;
      form.addEventListener('submit', function (e) {
        var field = document.getElementById('user-password-field');
        if (!field.value || confirmed) return;
        e.preventDefault();
        window.showConfirm(
          'Change password?',
          'This will change the password for "<%= targetUser.name %>". They\'ll need the new password to log in next time. Continue?',
          function () {
            confirmed = true;
            if (form.requestSubmit) form.requestSubmit();
            else form.submit();
          },
          { okLabel: 'Change password', variant: 'primary' }
        );
      });
    })();
  </script>
<% } %>

<% if (targetUser.id) { %>
  <form method="post" action="/users/<%= targetUser.id %>/delete" class="card"
        data-confirm="Remove this employee? They will no longer be able to log in or be assigned jobs.">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="btn btn-danger btn-sm">Remove employee</button>
  </form>
<% } %>
<%- include('../partials/footer') %>
