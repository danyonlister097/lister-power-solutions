<%- include('../partials/header', { title: 'Invoices', wide: true }) %>
<div class="page-header">
  <h1>Invoices</h1>
  <button type="button" class="btn btn-primary" id="new-invoice-open">+ New Invoice</button>
</div>

<div class="filters">
  <a class="<%= status === '' ? 'active' : '' %>" href="/invoices">All</a>
  <a class="<%= status === 'draft' ? 'active' : '' %>" href="/invoices?status=draft">Draft</a>
  <a class="<%= status === 'sent' ? 'active' : '' %>" href="/invoices?status=sent">Sent</a>
  <a class="<%= status === 'overdue' ? 'active' : '' %>" href="/invoices?status=overdue">Overdue</a>
  <a class="<%= status === 'paid' ? 'active' : '' %>" href="/invoices?status=paid">Paid</a>
  <a class="<%= status === 'cancelled' ? 'active' : '' %>" href="/invoices?status=cancelled">Cancelled</a>
</div>

<div class="section-heading">Invoices (<%= invoices.length %>)</div>
<% if (!invoices.length) { %>
  <p class="text-muted">No invoices yet.</p>
<% } else { %>
  <div class="timesheet-scroll">
    <table class="timesheet-table">
      <thead>
        <tr>
          <th>Invoice #</th>
          <th>Job</th>
          <th>Customer</th>
          <th>Status</th>
          <th>Total</th>
          <th>Due</th>
        </tr>
      </thead>
      <tbody>
        <% invoices.forEach(inv => { %>
          <tr>
            <td><a href="/invoices/<%= inv.id %>"><%= inv.invoice_number %></a></td>
            <td><%= inv.job_title %></td>
            <td><%= inv.customer_name %></td>
            <td><span class="badge badge-<%= inv.effective_status %>"><%= inv.effective_status %></span></td>
            <td><%= formatMoney(inv.total) %></td>
            <td><%= formatAuDate(inv.due_date) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<div id="new-invoice-modal" class="modal-backdrop" hidden>
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="new-invoice-modal-title">
    <button type="button" class="modal-close" id="new-invoice-close" aria-label="Close">&times;</button>
    <h2 id="new-invoice-modal-title">New invoice</h2>
    <% if (!jobs.length) { %>
      <p class="text-muted">Create a job first before raising an invoice.</p>
    <% } else { %>
      <form method="post" action="/invoices">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>
          Job
          <select name="job_id" required>
            <option value="">Select a job&hellip;</option>
            <% jobs.forEach(j => { %>
              <option value="<%= j.id %>"><%= j.title %> &mdash; <%= j.customer_name %></option>
            <% }) %>
          </select>
        </label>
        <p class="text-muted" style="font-size: 0.85rem;">Any cost items already logged on the job's Job Costing tab will be copied in as a starting point &mdash; you can adjust prices before sending.</p>
        <div class="actions">
          <button type="submit" class="btn btn-primary">Create invoice</button>
        </div>
      </form>
    <% } %>
  </div>
</div>
<script>
  (function () {
    var modal = document.getElementById('new-invoice-modal');
    var openBtn = document.getElementById('new-invoice-open');
    var closeBtn = document.getElementById('new-invoice-close');

    openBtn.addEventListener('click', function () { modal.hidden = false; });
    closeBtn.addEventListener('click', function () { modal.hidden = true; });
    modal.addEventListener('click', function (e) {
      if (e.target === modal) modal.hidden = true;
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.hidden) modal.hidden = true;
    });
  })();
</script>
<%- include('../partials/footer') %>
