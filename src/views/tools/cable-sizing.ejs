<%- include('../partials/header', { title: 'Cable Sizing Calculator' }) %>
<div class="page-header">
  <h1>Cable Sizing Calculator</h1>
  <a class="btn btn-secondary btn-sm" href="/tools">All tools</a>
</div>

<div class="flash flash-error" style="margin-bottom: 1.25rem;">
  <strong>Reference tool only.</strong> Figures are indicative values in the style of AS/NZS 3008.1.1 (copper/aluminium conductors, PVC/XLPE insulation). Always verify the final cable selection against the current official AS/NZS 3008.1.1 and AS/NZS 3000 standards, or a current manufacturer selection guide, before specifying or installing.
</div>

<div class="card card-narrow">
  <h2 class="leave-form-title">Load &amp; supply</h2>
  <div class="form-row form-row-2">
    <label>
      Design current (A)
      <input type="number" id="cs-current" step="0.1" min="0.1" value="20">
    </label>
    <label>
      Phase
      <select id="cs-phase">
        <option value="1">Single phase</option>
        <option value="3">Three phase</option>
      </select>
    </label>
  </div>
  <div class="form-row form-row-2">
    <label>
      Nominal voltage (V)
      <input type="number" id="cs-voltage" step="1" value="230">
    </label>
    <label>
      Cable length, one-way (m)
      <input type="number" id="cs-length" step="0.5" min="1" value="20">
    </label>
  </div>
  <label>
    Max allowable voltage drop (%)
    <input type="number" id="cs-vdrop" step="0.1" min="0.5" max="10" value="5">
  </label>
</div>

<div class="card card-narrow">
  <h2 class="leave-form-title">Cable &amp; installation</h2>
  <div class="form-row form-row-2">
    <label>
      Conductor material
      <select id="cs-conductor">
        <option value="copper">Copper</option>
        <option value="aluminium">Aluminium</option>
      </select>
    </label>
    <label>
      Insulation
      <select id="cs-insulation">
        <option value="pvc">PVC (75&deg;C) &mdash; V75</option>
        <option value="xlpe">XLPE (90&deg;C) &mdash; V90/X90</option>
      </select>
    </label>
  </div>
  <label>
    Installation method
    <select id="cs-method">
      <option value="enclosed">Enclosed &mdash; conduit/duct in wall or ceiling</option>
      <option value="clipped">Clipped direct / surface mounted</option>
      <option value="air">In free air, spaced from surface</option>
      <option value="buried">Direct buried in ground</option>
    </select>
  </label>
  <div class="form-row form-row-2">
    <label id="cs-ambient-field">
      Ambient temperature (&deg;C)
      <select id="cs-ambient">
        <option value="25">25</option>
        <option value="30">30</option>
        <option value="35">35</option>
        <option value="40" selected>40</option>
        <option value="45">45</option>
        <option value="50">50</option>
        <option value="55">55</option>
      </select>
    </label>
    <label id="cs-groundtemp-field" style="display:none;">
      Ground temperature (&deg;C)
      <select id="cs-groundtemp">
        <option value="15">15</option>
        <option value="20">20</option>
        <option value="25" selected>25</option>
        <option value="30">30</option>
        <option value="35">35</option>
        <option value="40">40</option>
      </select>
    </label>
    <label id="cs-soil-field" style="display:none;">
      Soil thermal resistivity (K.m/W)
      <select id="cs-soil">
        <option value="0.8">0.8</option>
        <option value="1.0">1.0</option>
        <option value="1.2" selected>1.2 (standard)</option>
        <option value="1.5">1.5</option>
        <option value="2.0">2.0</option>
        <option value="2.5">2.5</option>
        <option value="3.0">3.0</option>
      </select>
    </label>
    <label>
      Circuits grouped together
      <input type="number" id="cs-grouping" step="1" min="1" max="20" value="1">
    </label>
  </div>
</div>

<div class="card">
  <h2>Result</h2>
  <div id="cs-result-summary"></div>

  <div class="section-heading">All standard sizes</div>
  <div class="timesheet-scroll">
    <table class="timesheet-table" id="cs-result-table">
      <thead>
        <tr>
          <th>Size (mm&sup2;)</th>
          <th>Derated ampacity (A)</th>
          <th>Current OK?</th>
          <th>Voltage drop (V / %)</th>
          <th>Drop OK?</th>
        </tr>
      </thead>
      <tbody id="cs-result-body"></tbody>
    </table>
  </div>
</div>

<script src="/js/electrical-tables.js"></script>
<script src="/js/cable-sizing.js"></script>
<script>
  (function () {
    var els = {
      current: document.getElementById('cs-current'),
      phase: document.getElementById('cs-phase'),
      voltage: document.getElementById('cs-voltage'),
      length: document.getElementById('cs-length'),
      vdrop: document.getElementById('cs-vdrop'),
      conductor: document.getElementById('cs-conductor'),
      insulation: document.getElementById('cs-insulation'),
      method: document.getElementById('cs-method'),
      ambient: document.getElementById('cs-ambient'),
      groundtemp: document.getElementById('cs-groundtemp'),
      soil: document.getElementById('cs-soil'),
      grouping: document.getElementById('cs-grouping'),
    };
    var ambientField = document.getElementById('cs-ambient-field');
    var groundtempField = document.getElementById('cs-groundtemp-field');
    var soilField = document.getElementById('cs-soil-field');
    var summary = document.getElementById('cs-result-summary');
    var body = document.getElementById('cs-result-body');

    function fmt(n, dp) {
      return Number.isFinite(n) ? n.toFixed(dp === undefined ? 2 : dp) : '—';
    }

    function updateFieldVisibility() {
      var buried = els.method.value === 'buried';
      ambientField.style.display = buried ? 'none' : '';
      groundtempField.style.display = buried ? '' : 'none';
      soilField.style.display = buried ? '' : 'none';
    }

    function render() {
      updateFieldVisibility();

      var input = {
        current: Number.parseFloat(els.current.value) || 0,
        phase: Number.parseInt(els.phase.value, 10),
        voltage: Number.parseFloat(els.voltage.value) || 0,
        length: Number.parseFloat(els.length.value) || 0,
        maxVdropPct: Number.parseFloat(els.vdrop.value) || 5,
        conductor: els.conductor.value,
        insulation: els.insulation.value,
        method: els.method.value,
        ambient: Number.parseInt(els.ambient.value, 10),
        groundTemp: Number.parseInt(els.groundtemp.value, 10),
        soilResistivity: Number.parseFloat(els.soil.value),
        circuitsGrouped: Number.parseInt(els.grouping.value, 10) || 1,
      };

      var result = window.CableSizing.calculate(input);

      if (!result.recommended) {
        summary.innerHTML =
          '<div class="flash flash-error">No standard size up to 240mm&sup2; satisfies both the current rating and voltage drop requirements. Consider parallel runs, a shorter route, a lower voltage-drop allowance check, or specialist design advice.</div>';
      } else {
        var r = result.recommended;
        summary.innerHTML =
          '<div class="leave-stats">' +
          '<div class="leave-stat leave-stat-approved"><span class="leave-stat-value">' + r.size + ' mm&sup2;</span><span class="leave-stat-label">Recommended size</span></div>' +
          '<div class="leave-stat leave-stat-pending"><span class="leave-stat-value">' + fmt(r.deratedAmpacity, 1) + ' A</span><span class="leave-stat-label">Derated ampacity</span></div>' +
          '<div class="leave-stat leave-stat-declined"><span class="leave-stat-value">' + fmt(r.vdropPct, 2) + '%</span><span class="leave-stat-label">Voltage drop at this size</span></div>' +
          '</div>' +
          '<p class="text-muted" style="margin-top:0.75rem;">Governed by: <strong>' + result.governedBy + '</strong> &middot; Total derating factor applied: ' + fmt(result.totalDerating, 3) +
          ' (temperature ' + fmt(result.tempFactor, 3) + ' &times; grouping ' + fmt(result.groupFactor, 3) +
          (input.method === 'buried' ? ' &times; soil ' + fmt(result.soilFactor, 3) : '') + ') &middot; Allowed voltage drop: ' + fmt(result.allowedDropVolts, 2) + ' V</p>';
      }

      body.innerHTML = result.rows
        .map(function (row) {
          var isRecommended = result.recommended && row.size === result.recommended.size;
          return (
            '<tr' + (isRecommended ? ' style="background: var(--color-primary-tint);"' : '') + '>' +
            '<td>' + row.size + (isRecommended ? ' <span class="badge badge-completed">recommended</span>' : '') + '</td>' +
            '<td>' + fmt(row.deratedAmpacity, 1) + '</td>' +
            '<td>' + (row.ampacityOk ? '&#10003;' : '&#10007;') + '</td>' +
            '<td>' + fmt(row.vdropVolts, 2) + ' V / ' + fmt(row.vdropPct, 2) + '%</td>' +
            '<td>' + (row.vdropOk ? '&#10003;' : '&#10007;') + '</td>' +
            '</tr>'
          );
        })
        .join('');
    }

    els.phase.addEventListener('change', function () {
      // Nudge voltage to the common default for the selected phase, unless
      // the user has already typed something other than the other default.
      if (els.phase.value === '3' && els.voltage.value === '230') els.voltage.value = '400';
      if (els.phase.value === '1' && els.voltage.value === '400') els.voltage.value = '230';
    });

    Object.keys(els).forEach(function (key) {
      els[key].addEventListener('input', render);
      els[key].addEventListener('change', render);
    });

    render();
  })();
</script>
<%- include('../partials/footer') %>
