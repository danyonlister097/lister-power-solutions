<%- include('partials/header', { title: 'Reset password' }) %>
<div class="login-page">
  <div class="card card-narrow login-card">
    <img src="/img/logo-full.png" alt="Lister Power Solutions" class="login-logo">
    <% if (!valid) { %>
      <h1>Link expired</h1>
      <p class="login-subtitle">This reset link is invalid or has expired.</p>
      <p class="login-subtitle" style="margin-top:1rem;"><a href="/forgot-password">Request a new link</a></p>
    <% } else { %>
      <h1>Set a new password</h1>
      <% if (error) { %>
        <div class="flash flash-error"><%= error %></div>
      <% } %>
      <form method="post" action="/reset-password/<%= token %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>
          New password
          <input type="password" name="password" required minlength="8" autocomplete="new-password" autofocus>
        </label>
        <button type="submit" class="btn btn-primary login-submit">Set password</button>
      </form>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>
