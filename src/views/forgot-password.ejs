<%- include('partials/header', { title: 'Forgot password' }) %>
<div class="login-page">
  <div class="card card-narrow login-card">
    <img src="/img/logo-full.png" alt="Lister Power Solutions" class="login-logo">
    <h1>Reset your password</h1>
    <% if (sent) { %>
      <p class="login-subtitle">If that email has an account, a reset link is on its way. Check your inbox.</p>
      <p class="login-subtitle" style="margin-top:1rem;"><a href="/login">Back to log in</a></p>
    <% } else { %>
      <p class="login-subtitle">Enter your email and we'll send you a link to reset your password.</p>
      <form method="post" action="/forgot-password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>
          Email
          <input type="email" name="email" required autofocus>
        </label>
        <button type="submit" class="btn btn-primary login-submit">Send reset link</button>
      </form>
      <p class="login-subtitle" style="margin-top:1rem;margin-bottom:0;"><a href="/login">Back to log in</a></p>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>
